{
  "$schema": "https://raw.githubusercontent.com/fallow-rs/fallow/main/schema.json",
  "entry": [
    "src/index.{ts,tsx,js,jsx}",
    "src/main.{ts,tsx,js,jsx}"
  ],
  "duplicates": {
    // Hide pair-only clones; focus on widespread copy-paste
    // worth refactoring. Lower to 2 to report every duplicate pair.
    "minOccurrences": 3
    // Common additions (uncomment to enable):
    // "ignore": [
    //   "**/lib/**",          // for repos that publish transpiled output to lib/
    //   "**/legacy/**",       // for repos with legacy-build artifacts
    //   "**/__generated__/**", // Relay, GraphQL Code Generator
    //   "**/generated/**"     // OpenAPI, Protobuf codegen
    // ]
  },
  "rules": {
    "unused-dependencies": "warn"
  },
  "ignoreExports": [
    {
      "file": "src/lib/components/ui/alert-dialog/index.ts",
      "exports": ["*"]
    },
    {
      "file": "src/lib/components/ui/card/index.ts",
      "exports": ["*"]
    },
    {
      "file": "src/lib/components/ui/button/index.ts",
      "exports": ["*"]
    },
    {
      "file": "src/lib/components/ui/form/index.ts",
      "exports": ["*"]
    },
    {
      "file": "src/lib/components/ui/dialog/index.ts",
      "exports": ["*"]
    },
    {
      "file": "src/lib/components/ui/popover/index.ts",
      "exports": ["*"]
    },
    {
      "file": "src/lib/components/ui/tooltip/index.ts",
      "exports": ["*"]
    },
    {
      "file": "src/lib/components/ui/alert/index.ts",
      "exports": ["*"]
    },
    {
      "file": "src/lib/components/ui/label/index.ts",
      "exports": ["*"]
    },
    {
      "file": "src/lib/components/ui/accordion/index.ts",
      "exports": ["*"]
    },
    {
      "file": "src/lib/components/ui/avatar/index.ts",
      "exports": ["*"]
    },
    {
      "file": "src/lib/components/ui/command/index.ts",
      "exports": ["*"]
    },
    {
      "file": "src/lib/components/ui/dropdown-menu/index.ts",
      "exports": ["*"]
    },
    {
      "file": "src/lib/components/ui/empty/index.ts",
      "exports": ["*"]
    },
    {
      "file": "src/lib/components/ui/hover-card/index.ts",
      "exports": ["*"]
    },
    {
      "file": "src/lib/components/ui/input/index.ts",
      "exports": ["*"]
    },
    {
      "file": "src/lib/components/ui/input-group/index.ts",
      "exports": ["*"]
    },
    {
      "file": "src/lib/components/ui/input-otp/index.ts",
      "exports": ["*"]
    },
    {
      "file": "src/lib/components/ui/scroll-area/index.ts",
      "exports": ["*"]
